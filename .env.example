# ─────────────────────────────────────────────────────────────
# pepper archive configuration. Copy to `.env` and fill in.
# `.env` is gitignored; never commit real credentials.
# ─────────────────────────────────────────────────────────────

# The Reddit account being archived (no u/ prefix).
PEPPER_REDDIT_USERNAME=newppinpoint

# Where all collected data/media/exports live (gitignored).
PEPPER_DATA_DIR=./data

# ── Reddit official API (PRAW) — OAuth "script" app ──
# Register at https://old.reddit.com/prefs/apps  (choose "script").
# Leave blank to run on public archives only (Arctic Shift + PullPush).
PEPPER_REDDIT_CLIENT_ID=
PEPPER_REDDIT_CLIENT_SECRET=
# user_agent must identify you, e.g. "macos:pepper-archive:0.1 (by u/newppinpoint)"
PEPPER_REDDIT_USER_AGENT=macos:pepper-archive:0.1 (by u/newppinpoint)
# Password flow (optional). Only needed to read your own private/removed data.
PEPPER_REDDIT_PASSWORD=

# ── Anthropic (LLM persona dossier via Batch API) ──
# Leave blank to skip the dossier stage.
ANTHROPIC_API_KEY=
# Model + per-MTok USD prices used ONLY for the pre-run cost estimate.
PEPPER_LLM_MODEL=claude-sonnet-5
PEPPER_LLM_PRICE_INPUT_PER_MTOK=3.0
PEPPER_LLM_PRICE_OUTPUT_PER_MTOK=15.0
# Batch API applies a 50% discount; the estimator halves the above.

# ── Rate limits (requests/sec) — safe defaults; override if needed ──
PEPPER_RL_PRAW_PER_MIN=55
PEPPER_RL_ARCTICSHIFT_PER_SEC=1
PEPPER_RL_PULLPUSH_PER_SEC=0.2

# ── Feature flags ──
# Include content deleted-by-user / removed-by-mod recovered from archives.
PEPPER_INCLUDE_DELETED=true
