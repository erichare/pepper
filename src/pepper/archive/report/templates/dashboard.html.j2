<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>u/{{ username }} — pepper archive</title>
<style>
  :root { color-scheme: light dark; }
  body { font-family: -apple-system, system-ui, Segoe UI, Roboto, sans-serif; margin: 0; background: #0f1115; color: #e6e6e6; }
  header { padding: 24px 32px; background: linear-gradient(135deg,#1b2735,#0f1115); border-bottom: 1px solid #263042; }
  h1 { margin: 0 0 4px; font-size: 24px; }
  .sub { color: #9aa7b8; font-size: 14px; }
  .cards { display: flex; flex-wrap: wrap; gap: 12px; padding: 20px 32px; }
  .card { background: #171b22; border: 1px solid #263042; border-radius: 10px; padding: 14px 18px; min-width: 120px; }
  .card .n { font-size: 22px; font-weight: 700; }
  .card .l { font-size: 12px; color: #9aa7b8; text-transform: uppercase; letter-spacing: .04em; }
  section { padding: 8px 32px 28px; }
  .chart { background: #12151b; border: 1px solid #263042; border-radius: 10px; margin: 16px 0; padding: 6px; }
  h2 { border-bottom: 1px solid #263042; padding-bottom: 6px; margin-top: 28px; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  ul { line-height: 1.5; }
  table { border-collapse: collapse; width: 100%; font-size: 14px; }
  th, td { border: 1px solid #263042; padding: 6px 10px; text-align: left; }
  a { color: #6db3ff; }
  @media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }
</style>
</head>
<body>
<header>
  <h1>u/{{ username }}</h1>
  <div class="sub">Reddit archive &amp; persona dashboard — generated by pepper</div>
</header>

<div class="cards">
  <div class="card"><div class="n">{{ totals['items'] or 0 }}</div><div class="l">items</div></div>
  <div class="card"><div class="n">{{ totals.submissions or 0 }}</div><div class="l">posts</div></div>
  <div class="card"><div class="n">{{ totals.comments or 0 }}</div><div class="l">comments</div></div>
  <div class="card"><div class="n">{{ totals.subreddits or 0 }}</div><div class="l">subreddits</div></div>
</div>

<section>
  {% for div in chart_divs %}
  <div class="chart">{{ div | safe }}</div>
  {% endfor %}
</section>

{% if dossier %}
<section>
  <h2>Persona</h2>
  <p>{{ dossier.summary }}</p>
  <div class="grid">
    {% if dossier.interests %}<div><h3>Interests</h3><ul>{% for x in dossier.interests %}<li>{{ x }}</li>{% endfor %}</ul></div>{% endif %}
    {% if dossier['values'] %}<div><h3>Values</h3><ul>{% for x in dossier['values'] %}<li>{{ x }}</li>{% endfor %}</ul></div>{% endif %}
  </div>
  {% if dossier.voice_guide %}
  <h3>Voice guide</h3>
  <p><b>Tone:</b> {{ dossier.voice_guide.tone }}</p>
  {% endif %}
  {% if dossier.biographical_facts %}
  <h3>Self-disclosed facts</h3>
  <table>
    <tr><th>Category</th><th>Fact</th><th>Confidence</th><th>Sources</th></tr>
    {% for f in dossier.biographical_facts %}
    <tr><td>{{ f.category }}</td><td>{{ f.value }}</td><td>{{ f.confidence }}</td>
      <td>{% for s in f.source_links %}<a href="{{ s.permalink or '#' }}">{{ s.id }}</a>{% if not loop.last %}, {% endif %}{% endfor %}</td></tr>
    {% endfor %}
  </table>
  {% endif %}
</section>
{% endif %}

{% if linguistic and not linguistic.empty %}
<section>
  <h2>Language</h2>
  <p>{{ linguistic.vocabulary.total_words }} words · {{ linguistic.vocabulary.unique_words }} unique · richness {{ linguistic.vocabulary.richness }}
     · question ratio {{ linguistic.tone.question_ratio }}</p>
  <p><b>Most-used:</b> {{ linguistic.top_words[:30] | map(attribute='word') | join(", ") }}</p>
</section>
{% endif %}

{% if graph and not graph.empty %}
<section>
  <h2>Interactions</h2>
  <p>{{ graph.metrics.distinct_interlocutors }} distinct people replied to.</p>
  <ul>{% for i in graph.top_interlocutors[:15] %}<li>u/{{ i.author }} — {{ i.replies }} replies</li>{% endfor %}</ul>
</section>
{% endif %}

<footer style="padding:20px 32px;color:#6b7889;font-size:12px;">pepper archive · self-contained report</footer>
</body>
</html>
