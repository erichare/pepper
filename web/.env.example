# ── The Pepper Dossier — web app environment ──────────────────────
# Copy to .env.local for local dev; set the same keys in Vercel for deploy.

# REQUIRED for the "What would newppinpoint say?" reply generation.
ANTHROPIC_API_KEY=

# Model + cost guards for /api/reply (optional; sensible defaults shown).
PERSONA_MODEL=claude-sonnet-5
DAILY_GENERATION_CAP=500

# RECOMMENDED for the live /feed. Reddit blocks its public .json endpoints from
# datacenter IPs (incl. Vercel) and closed self-serve API access in Nov 2025, so
# the direct paths can't reach Reddit from the cloud. Set an Apify API token and
# the feed scrapes r/Chipotle via Apify's residential proxies instead. Token:
# apify.com → Settings → API & Integrations → Personal API token. Results are
# KV-cached so the scraper runs at most once every few minutes (pennies of usage).
APIFY_TOKEN=

# Optional legacy path: app-only OAuth via oauth.reddit.com, used only if
# APIFY_TOKEN is unset and you have pre-Nov-2025 credentials. New "script" apps
# generally can no longer be created. Falls back to public JSON (403s from cloud).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:pepper-dossier:v1.0.0 (by /u/newppinpoint)

# OPTIONAL — persistent reply cache + cross-instance rate limiting.
# Without these the app falls back to per-instance in-memory limits (fine for
# low traffic). Add an Upstash Redis integration on Vercel to enable.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
